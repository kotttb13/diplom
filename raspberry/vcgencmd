#!/usr/bin/env bash
set -euo pipefail

# If a real vcgencmd exists (from libraspberrypi-bin), prefer it.
if command -v /usr/bin/vcgencmd >/dev/null 2>&1 && [[ "${BASH_SOURCE[0]}" != "/usr/bin/vcgencmd" ]]; then
  exec /usr/bin/vcgencmd "$@"
fi

cmd="${1:-}"
arg="${2:-}"

case "${cmd} ${arg}" in
  "measure_temp ")
    echo "temp=46.2'C"
    ;;
  "measure_clock arm")
    echo "frequency(48)=1800000000"
    ;;
  "get_mem gpu")
    echo "gpu=512M"
    ;;
  "get_throttled ")
    echo "throttled=0x0"
    ;;
  "version ")
    echo "vcgencmd version 1.0 (docker-rpi-sim)"
    ;;
  *)
    echo "vcgencmd: unknown command: $*" >&2
    echo "Supported: measure_temp | measure_clock arm | get_throttled | version" >&2
    exit 1
    ;;
esac

